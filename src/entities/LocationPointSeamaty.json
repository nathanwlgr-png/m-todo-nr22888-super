{
  "name": "LocationPointSeamaty",
  "type": "object",
  "description": "Pontos de localização do mapa Seamaty — clientes, leads, oportunidades",
  "properties": {
    "tipo": {
      "type": "string",
      "enum": ["cliente", "lead", "oportunidade_equipamento", "comodato", "recompra_insumo", "inativo", "pós_venda"],
      "description": "Tipo de ponto no mapa"
    },
    "client_id": {
      "type": "string",
      "description": "ID do cliente (se aplicável)"
    },
    "lead_id": {
      "type": "string",
      "description": "ID do lead (se aplicável)"
    },
    "nome_clinica": {
      "type": "string",
      "description": "Nome da clínica/empresa"
    },
    "responsavel": {
      "type": "string",
      "description": "Nome do responsável/proprietário"
    },
    "telefone": {
      "type": "string",
      "description": "Telefone para contato"
    },
    "whatsapp": {
      "type": "string",
      "description": "WhatsApp (formato: 5511999999999)"
    },
    "email": {
      "type": "string",
      "description": "Email para contato"
    },
    "cidade": {
      "type": "string",
      "description": "Cidade"
    },
    "uf": {
      "type": "string",
      "description": "UF"
    },
    "bairro": {
      "type": "string",
      "description": "Bairro (se disponível)"
    },
    "endereco_completo": {
      "type": "string",
      "description": "Endereço completo"
    },
    "latitude": {
      "type": "number",
      "description": "Latitude do ponto exato"
    },
    "longitude": {
      "type": "number",
      "description": "Longitude do ponto exato"
    },
    "google_maps_url": {
      "type": "string",
      "description": "Link Google Maps do endereço"
    },
    "geolocalizacao_status": {
      "type": "string",
      "enum": ["local_exato", "marcador_territorial", "pendente_geocodificacao", "sem_endereco", "dado_inconsistente"],
      "default": "local_exato",
      "description": "Tipo de geolocalização"
    },
    "equipamentos_atuais": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["SMT-120VP", "QT3", "VG1", "VG2", "VI1", "3DX", "VBC50A", "VQ1", "nenhum"]
      },
      "description": "Equipamentos atualmente instalados"
    },
    "equipamento_gap": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Equipamentos que faltam (oportunidade)"
    },
    "potencial_comodato": {
      "type": "boolean",
      "default": false,
      "description": "Tem potencial para comodato"
    },
    "perfil_cliente": {
      "type": "string",
      "enum": ["clinica_pequena", "clinica_media", "hospital_veterinario", "laboratorio_terceirizado", "referencia_regional"],
      "description": "Perfil clínico/comercial"
    },
    "score_oportunidade": {
      "type": "number",
      "description": "Score de oportunidade (0-100): 80+ A_QUENTE, 60-79 B_MORNO, 40-59 C_FRIO, <40 D_BAIXA"
    },
    "prioridade": {
      "type": "string",
      "enum": ["a_quente", "b_morno", "c_frio", "d_baixa_prioridade"],
      "description": "Classificação por score"
    },
    "status_funil": {
      "type": "string",
      "enum": ["lead", "qualificado", "proposta", "negociacao", "fechado", "perdido"],
      "description": "Estágio no funil de vendas"
    },
    "ultima_compra": {
      "type": "string",
      "format": "date",
      "description": "Data da última compra"
    },
    "dias_sem_compra": {
      "type": "number",
      "description": "Dias desde a última compra"
    },
    "proxima_acao": {
      "type": "string",
      "description": "Próxima ação recomendada"
    },
    "origem_dado": {
      "type": "string",
      "enum": ["crm_seamaty", "planilha_importada", "cliente_cadastro", "investigacao_campo", "manual"],
      "description": "Origem dos dados"
    },
    "cor_pin": {
      "type": "string",
      "description": "Cor do pin (hex): verde, laranja, cinza, dourado, vermelho, roxo, azul, amarelo, preto"
    },
    "icone": {
      "type": "string",
      "enum": ["pin_cliente", "pin_lead", "pin_oportunidade", "pin_comodato", "pin_recompra", "pin_inativo", "pin_pos_venda"],
      "description": "Ícone do pin"
    },
    "atualizado_em": {
      "type": "string",
      "format": "date-time",
      "description": "Última atualização"
    }
  },
  "required": ["tipo", "nome_clinica", "cidade", "uf"],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    }
  }
}