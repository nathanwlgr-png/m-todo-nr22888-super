    },
    "contract_signature_date": {
      "type": "string",
      "format": "date",
      "description": "Data agendada para assinatura do contrato"
    },
    "contract_renewal_date": {
      "type": "string",
      "format": "date",
      "description": "Data de renovação do contrato (para alertas automáticos)"
    },
