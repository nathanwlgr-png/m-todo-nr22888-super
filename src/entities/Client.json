    },
    "company_size": {
      "type": "string",
      "enum": [
        "micro",
        "pequena",
        "media",
        "grande"
      ],
      "description": "Tamanho da empresa"
    },
    "industry": {
      "type": "string",
      "description": "Segmento/indústria do cliente"
    },
    "website": {
      "type": "string",
      "description": "Website da clínica/empresa"
    },
    "last_contact_date": {
      "type": "string",
      "format": "date",
      "description": "Data do último contato realizado"
    },
    "last_contact_follow_up_date": {
      "type": "string",
      "format": "date",
      "description": "Data do último follow-up de contato realizado"
    },
    "next_contact_date": {
      "type": "string",
      "format": "date",
      "description": "Data agendada para próximo contato/follow-up"
    },
    "last_purchase_date": {
      "type": "string",
      "format": "date",
      "description": "Data da última compra realizada pelo cliente"
    },
    "average_purchase_value": {
      "type": "number",
      "description": "Valor médio de compra do cliente em R$"
    },
    "purchased_products": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs dos produtos comprados pelo cliente (relacionamento com entidade Product)"
    },
    "lead_source": {
      "type": "string",
      "enum": [
        "indicacao",
        "google",
        "redes_sociais",
        "evento",
        "telefone",
        "email",
        "site",
        "parceiro",
        "importacao_planilha",
        "analise_mercado_ia",
        "outro"
      ],
      "description": "Origem do lead"
    },
    "life_path_number": {
      "type": "number",
      "description": "Número do caminho de vida (data de nascimento)"
    },
    "numerology_number": {
      "type": "number",
      "description": "Número numerológico calculado (nome)"
    },
    "behavioral_profile": {
      "type": "string",
      "description": "Perfil comportamental"
    },
    "decision_style": {
      "type": "string",
      "description": "Estilo de decisão"
    },
    "approach_tips": {
      "type": "string",
      "description": "Dicas de abordagem baseadas em numerologia e perfil"
    },
    "client_tone": {
      "type": "string",
      "enum": [
        "assertivo",
        "analitico",
        "receptivo",
        "entusiasmado",
        "cauteloso",
        "direto",
        "emocional"
      ],
      "description": "Tom de voz e estilo de comunicação observado"
    },
