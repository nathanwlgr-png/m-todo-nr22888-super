      "type": "string",
      "description": "Código externo do cliente (sistema legado)"
    },
    "full_name": {
      "type": "string",
      "description": "IMPORTANTE: Nome completo do PROPRIETÁRIO ou VETERINÁRIO RESPONSÁVEL (NÃO da clínica). Este é o decisor principal."
    },
    "first_name": {
      "type": "string",
      "description": "Primeiro nome do PROPRIETÁRIO ou VETERINÁRIO (NÃO da clínica)"
    },
    "birthdate": {
      "type": "string",
      "format": "date",
      "description": "Data de nascimento do proprietário/veterinário responsável"
    },
    "clinic_opening_date": {
      "type": "string",
      "format": "date",
      "description": "Data de inauguração da clínica (usado para parabéns se não houver birthdate)"
    },
    "cpf": {
      "type": "string",
      "description": "CPF do proprietário/veterinário responsável"
    },
    "cnpj": {
      "type": "string",
      "description": "CNPJ da empresa"
    },
    "razao_social": {
      "type": "string",
      "description": "Razão social da empresa"
    },
    "email": {
      "type": "string",
      "description": "Email do cliente (proprietário/veterinário)"
    },
    "instagram_handle": {
      "type": "string",
      "description": "Instagram da clínica/pessoa (@usuario)"
    },
    "facebook_url": {
      "type": "string",
      "description": "URL da página no Facebook"
    },
    "social_media_analysis": {
      "type": "string",
      "description": "Análise do perfil de redes sociais (JSON stringificado)"
    },
    "ai_website_analysis": {
      "type": "string",
      "description": "Análise do website (serviços, especialização, equipamentos) - JSON"
    },
    "equipment_interest": {
      "type": "string",
      "description": "Equipamento de interesse do cliente (VG2, Hematologia, etc)"
    },
    "contract_signature_email": {
      "type": "string",
      "description": "Email para envio de contratos e assinaturas eletrônicas"
    },
    "phone": {
      "type": "string",
      "description": "Telefone com WhatsApp (formato: 5511999999999) - OPCIONAL - Editável a qualquer momento"
    },
    "address": {
      "type": "string",
      "description": "Endereço completo"
    },
    "cep": {
      "type": "string",
      "description": "CEP do endereço"
    },
    "city": {
      "type": "string",
      "description": "Cidade do cliente"
    },
    "clinic_name": {
      "type": "string",
      "description": "Nome da clínica/hospital (separado do nome do proprietário/veterinário)"
    },
    "current_equipment": {
      "type": "string",
      "description": "Equipamento/máquina atual que o cliente possui"
    },
    "equipment_sold": {
      "type": "string",
      "description": "Equipamento vendido para o cliente"
    },
    "sale_closed": {
      "type": "boolean",
