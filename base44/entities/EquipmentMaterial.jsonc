    },
    "price_range": {
      "type": "string",
      "description": "Faixa de pre\u00e7o"
    },
    "catchphrases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Frases de efeito para vendas"
    },
    "whatsapp_templates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Templates de mensagem WhatsApp"
    },
    "email_templates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Templates de email"
    },
    "differentiators": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Diferenciais competitivos \u00fanicos no mercado"
    },
    "competitive_advantages": {
      "type": "object",
      "properties": {
        "vs_competitor": {
          "type": "string"
        },
        "unique_features": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cost_benefit": {
          "type": "string"
        },
        "exclusivity": {
          "type": "string"
        }
      },
      "description": "Vantagens competitivas detalhadas"
    },
    "persuasion_triggers": {
      "type": "object",
      "properties": {
        "scarcity": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authority": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "social_proof": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "urgency": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reciprocity": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Gatilhos de persuas\u00e3o por princ\u00edpio de Cialdini"
    },
    "clinical_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "case_title": {
            "type": "string"
          },
          "problem": {
            "type": "string"
          },
          "solution": {
            "type": "string"
          },
