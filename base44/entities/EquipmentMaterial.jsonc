{
  "name": "EquipmentMaterial",
  "type": "object",
  "properties": {
    "equipment_name": {
      "type": "string",
      "description": "Nome do equipamento"
    },
    "category": {
      "type": "string",
      "description": "Categoria do equipamento"
    },
    "price": {
      "type": "number",
      "description": "Pre\u00e7o do equipamento em R$"
    },
    "summary": {
      "type": "string",
      "description": "Resumo das caracter\u00edsticas"
    },
    "technical_specs": {
      "type": "object",
      "description": "Especifica\u00e7\u00f5es t\u00e9cnicas detalhadas"
    },
    "image_urls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs das imagens do equipamento"
    },
    "video_url": {
      "type": "string",
      "description": "URL do v\u00eddeo demonstrativo"
    },
    "benefits": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Principais benef\u00edcios"
    },
    "target_profile": {
