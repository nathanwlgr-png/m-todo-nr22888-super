{
  "name": "AIInteractionLog",
  "type": "object",
  "description": "Log de intera\u00e7\u00f5es com a Central IA Master NR22888",
  "properties": {
    "user_message": {
      "type": "string",
      "description": "Mensagem enviada pelo usu\u00e1rio"
    },
    "ai_response": {
      "type": "string",
      "description": "Resposta gerada pela IA"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "briefing",
        "ranking",
        "prepare_visit",
        "whatsapp",
        "marketing",
        "route",
        "field_research",
        "numerology",
        "general"
      ],
      "description": "Tipo de a\u00e7\u00e3o solicitada"
    },
    "client_id": {
      "type": "string",
      "description": "ID do cliente relacionado (opcional)"
    },
    "client_name": {
      "type": "string",
      "description": "Nome do cliente (cache)"
    },
    "source": {
      "type": "string",
      "enum": [
        "central_ia_master",
        "whatsapp_agent",
        "automation",
        "api"
      ],
      "default": "central_ia_master",
      "description": "Origem da intera\u00e7\u00e3o"
    },
    "tokens_used": {
      "type": "number",
      "description": "Tokens OpenAI consumidos"
    },
    "model_used": {
      "type": "string",
      "description": "Modelo OpenAI utilizado"
    },
    "duration_ms": {
      "type": "number",
      "description": "Tempo de resposta em ms"
    },
    "success": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "action_type",
    "user_message"
  ]
}